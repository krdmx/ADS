generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationTicketStatus {
  processing
  completed
  failed
}

enum ApplicationBoardStage {
  resume_sent
  hr_screening
  technical_interview
  system_design
  algorithm_session
  custom_status
  passed
  failed
  ignored
}

enum ApplicationCompensationCurrency {
  USD
  EUR
  GBP
  ILS
  PLN
  CAD
  AUD
}

enum ApplicationCompensationPeriod {
  yearly
  monthly
  hourly
}

model AppMetadata {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhitelistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String              @id
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  profile   UserProfile?
  tickets          ApplicationTicket[]
}

model UserProfile {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName   String   @default("")
  baseCv     String   @default("")
  workTasks  String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ApplicationTicket {
  id                 String                  @id @default(cuid())
  userId             String
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             ApplicationTicketStatus
  companyName        String
  companyWebsite     String?
  positionTitle      String?
  jdUrl              String?
  vacancyDescription String
  lastError          String?
  result             ApplicationTicketResult?
  tracker            ApplicationTracker?
  companySummary     ApplicationTicketCompanySummary?
  vacancySummary     ApplicationTicketVacancySummary?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([userId, createdAt])
}

model ApplicationTicketResult {
  ticketId            String            @id
  ticket              ApplicationTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  cvMarkdown          String
  coverLetterMarkdown String
  personalNote        String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model ApplicationTicketCompanySummary {
  ticketId                    String            @id
  ticket                      ApplicationTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  companyName                 String
  companyType                 String?
  companySize                 String?
  companyIndustry             String?
  companyBusinessModel        String?
  companyProductType          String?
  companyFounded              String?
  companyHq                   String?
  companyFundingStage         String?
  cultureValues               String[]
  cultureWorkStyle            String?
  cultureEngineeringCulture   String?
  flagsGreen                  String[]
  flagsRed                    String[]
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
}

model ApplicationTicketVacancySummary {
  ticketId                         String            @id
  ticket                           ApplicationTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  positionTitle                    String
  positionSeniority                String
  positionTeamContext              String
  positionKeyTasks                 String[]
  positionRequiredStack            String[]
  positionNiceToHaveStack          String[]
  positionSalaryMin                Float?
  positionSalaryMax                Float?
  positionSalaryCurrency           String?
  positionInterviewProcess         String[]
  positionGrowthOpportunities      String?
  screeningPrepWhyHireMe           String[]
  screeningPrepSmartQuestionsHr    String[]
  screeningPrepSmartQuestionsTech  String[]
  createdAt                        DateTime          @default(now())
  updatedAt                        DateTime          @updatedAt
}

model ApplicationTracker {
  ticketId          String                          @id
  ticket            ApplicationTicket               @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  currentStage      ApplicationBoardStage          @default(resume_sent)
  lastTransitionAt  DateTime                       @default(now())
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  stageRecords      ApplicationTrackerStageRecord[]
  transitionLogs    ApplicationTrackerTransitionLog[]
}

model ApplicationTrackerStageRecord {
  id                       String                          @id @default(cuid())
  trackerId                String
  tracker                  ApplicationTracker              @relation(fields: [trackerId], references: [ticketId], onDelete: Cascade)
  stageKey                 ApplicationBoardStage
  submittedAt              DateTime?
  jobSite                  String?
  jobSiteOther             String?
  notes                    String?
  roundNumber              Int?
  customStatusLabel        String?
  failureReason            String?
  salaryMinAmount          Float?
  salaryMaxAmount          Float?
  salaryCurrency           ApplicationCompensationCurrency?
  salaryPeriod             ApplicationCompensationPeriod?
  salaryNormalizedMinAmount Float?
  salaryNormalizedMaxAmount Float?
  createdAt                DateTime                        @default(now())
  updatedAt                DateTime                        @updatedAt
  questions                ApplicationTrackerStageQuestion[]

  @@unique([trackerId, stageKey])
  @@index([stageKey])
  @@index([salaryNormalizedMinAmount])
  @@index([salaryNormalizedMaxAmount])
}

model ApplicationTrackerStageQuestion {
  id            String                        @id @default(cuid())
  stageRecordId String
  stageRecord   ApplicationTrackerStageRecord @relation(fields: [stageRecordId], references: [id], onDelete: Cascade)
  sortOrder     Int
  prompt        String
  answer        String?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  @@index([stageRecordId, sortOrder])
}

model ApplicationTrackerTransitionLog {
  id        String               @id @default(cuid())
  trackerId String
  tracker   ApplicationTracker   @relation(fields: [trackerId], references: [ticketId], onDelete: Cascade)
  fromStage ApplicationBoardStage?
  toStage   ApplicationBoardStage
  createdAt DateTime             @default(now())

  @@index([trackerId, createdAt])
}
